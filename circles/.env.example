# Copy this file to .env and fill in real values

CIRCLES_DOMAIN=yourdomain.com
CIRCLES_INSTANCE_NAME=Circles Server
CIRCLES_NODE_ENV=production # or development
CIRCLES_HOST=circles
CIRCLES_PORT=3000
USE_SSL=true

MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=YOUR_PASSWORD_HERE

MINIO_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_ROOT_USERNAME=minioadmin
MINIO_ROOT_PASSWORD=YOUR_PASSWORD_HERE 

QDRANT_HOST=qdrant

SYNAPSE_POSTGRES_USERNAME=synapse_username
SYNAPSE_POSTGRES_PASSWORD=YOUR_PASSWORD_HERE

MATRIX_HOST=synapse
MATRIX_PORT=8008
NEXT_PUBLIC_MATRIX_URL=https://kamooni.org
NEXT_PUBLIC_MATRIX_DOMAIN=makecircles.org
MATRIX_DOMAIN=yourdomain.com
MATRIX_SHARED_SECRET=your_matrix_shared_secret
MATRIX_ADMIN_PASSWORD=your_matrix_admin_password

CIRCLES_URL=http://127.0.0.1
CIRCLES_REGISTRY_URL=http://161.35.244.159:3001
CIRCLES_JWT_SECRET=your_jwt_secret
NEXT_PUBLIC_ENABLE_VIBE_ID=true
OPENAI_API_KEY=your_openai_api_key
MAPBOX_API_KEY=your_mapbox_api_key
CRON_SECRET=your_secret_key_for_cron_jobs

# VibeID credential issuer. Generate a dev key with:
# npm run generate:vibeid-issuer-key
VIBE_ID_CREDENTIAL_ISSUER_PRIVATE_JWK=base64url_encoded_private_p256_jwk
VIBE_ID_CREDENTIAL_ISSUER_DID=did:vibe:p256:derived_public_issuer_did
VIBE_ID_CREDENTIAL_ISSUER_NAME=Kamooni
VIBE_ID_CREDENTIAL_ISSUER_TAGLINE=Building a thriving future together

POSTMARK_API_TOKEN=YOUR_TOKEN_HERE
POSTMARK_SENDER_EMAIL=hello@socialsystems.io

DONORBOX_EMAIL=your_donorbox_email
DONORBOX_API_KEY=your_donorbox_api_key
DONORBOX_WEBHOOK_SECRET=your_donorbox_webhook_secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_MONTHLY=price_your_monthly_membership_price
STRIPE_PRICE_MONTHLY_1=price_your_monthly_supporter_tier_1
STRIPE_PRICE_MONTHLY_2=price_your_monthly_supporter_tier_2
STRIPE_PRICE_MONTHLY_5=price_your_monthly_supporter_tier_5
STRIPE_PRICE_MONTHLY_10=price_your_monthly_supporter_tier_10
STRIPE_PRICE_YEARLY=price_your_yearly_membership_price
NEXT_PUBLIC_APP_URL=http://localhost:3000

TEST=TEST
MONGODB_URI=mongodb://USER:PASSWORD@127.0.0.1:27017/circles?authSource=admin

# ALTCHA signup CAPTCHA HMAC key (generate with: openssl rand -hex 32)
ALTCHA_HMAC_KEY=your_altcha_hmac_key
